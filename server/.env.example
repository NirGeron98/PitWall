# Local development can omit DATABASE_URL to use server/pitwall.db.
# Production should use Neon Postgres, preferably the pooled connection string.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Clerk authentication. CLERK_ISSUER is your Clerk Frontend API domain
# (Dashboard -> API Keys -> "Frontend API URL"), e.g. https://<slug>.clerk.accounts.dev
CLERK_ISSUER=https://your-slug.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Legacy JWT settings (unused now that auth is handled by Clerk; kept for reference).
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Use comma-separated origins in production.
CORS_ORIGINS=http://localhost:5173,https://your-pitwall-frontend.vercel.app
FRONTEND_URL=https://your-pitwall-frontend.vercel.app

# Render has ephemeral storage; /tmp is the right place for transient FastF1 cache.
FASTF1_CACHE_DIR=/tmp/fastf1-cache

# Required only for POST /api/admin/sync.
ADMIN_SYNC_SECRET=replace-with-a-long-random-secret
